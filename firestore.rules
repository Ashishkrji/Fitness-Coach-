rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /inquiries/{inquiry} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'phone', 'service', 'message', 'createdAt'])
                   && request.resource.data.keys().size() == 6
                   && request.resource.data['name'] is string
                   && request.resource.data['email'] is string
                   && request.resource.data['phone'] is string
                   && request.resource.data['service'] is string
                   && request.resource.data['message'] is string
                   && request.resource.data['createdAt'] == request.time;
    }
    match /blog/{post} {
      allow read: if true;
    }
    match /testimonials/{t} {
      allow read: if true;
    }
    match /transformations/{tr} {
      allow read: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
